{
  "backend": {
    "host": "127.0.0.1",
    "port": 8766,
    "baseUrl": "http://127.0.0.1:8766",
    "requestTimeoutMs": 20000
  },
  "cache": {
    "directory": "./cache/images",
    "maxDownloadBytes": 26214400
  },
  "extension": {
    "minimumImageDimensionPx": 300,
    "sliceMaxWidthPx": 8192,
    "sliceMaxHeightPx": 2200,
    "prefetchMarginPx": 1800,
    "cancelDistancePx": 3600,
    "aheadProcessingEnabled": true,
    "aheadProcessingImageLimit": 3,
    "maxConcurrentRequests": 2,
    "retryMaxAttempts": 3,
    "retryBaseDelayMs": 750,
    "memoryCacheMaxEntries": 64,
    "indexedDbCacheMaxEntries": 500,
    "fadeMs": 180
  },
  "inference": {
    "enabled": true,
    "provider": "auto",
    "runtime": "onnxruntime",
    "defaultModel": "anime_x4",
    "tileSize": 256,
    "enhanceLevel": 0.35
  }
}
