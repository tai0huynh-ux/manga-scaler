{
  "backend": {
    "host": "127.0.0.1",
    "port": 8765,
    "baseUrl": "http://127.0.0.1:8765",
    "requestTimeoutMs": 20000
  },
  "cache": {
    "directory": "./cache/images",
    "maxDownloadBytes": 26214400
  },
  "extension": {
    "minimumImageDimensionPx": 300,
    "prefetchMarginPx": 1800,
    "cancelDistancePx": 3600,
    "maxConcurrentRequests": 2,
    "retryMaxAttempts": 3,
    "retryBaseDelayMs": 750,
    "memoryCacheMaxEntries": 64,
    "indexedDbCacheMaxEntries": 500,
    "fadeMs": 180
  },
  "inference": {
    "enabled": false,
    "provider": "none",
    "futureProvider": "onnxruntime-real-esrgan"
  }
}
