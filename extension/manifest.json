{
  "manifest_version": 3,
  "name": "Universal AI Image Enhancer",
  "description": "Local DirectML enhancement for manga, artwork, anime, and photos.",
  "version": "0.2.0",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Universal AI Image Enhancer"
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/config.js", "src/content.js"],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "http://127.0.0.1:8766/*",
    "http://localhost:8766/*",
    "http://*/*",
    "https://*/*"
  ],
  "permissions": ["storage", "tabs", "scripting", "alarms", "declarativeNetRequestWithHostAccess", "nativeMessaging"]
}
